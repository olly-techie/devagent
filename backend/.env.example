# ════════════════════════════════════════════════════════
#  DevAgent — Environment Variables
#  Copy to .env for local dev.
#  On Railway: set these in the Variables tab (not this file).
# ════════════════════════════════════════════════════════

# ── Database (Railway auto-fills these if you add MySQL) ─
# Railway injects MYSQL_* variables — map them here:
DB_HOST=mysql.railway.internal   # Railway internal host
DB_PORT=3306
DB_NAME=railway                  # Default Railway DB name
DB_USER=root
DB_PASS=                         # Railway generates this

# ── GitHub OAuth App ──────────────────────────────────────
# 1. Go to github.com/settings/developers → OAuth Apps → New
# 2. Set Homepage URL: https://your-backend.up.railway.app
# 3. Set Callback URL: https://your-backend.up.railway.app/api/connect-github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://your-backend.up.railway.app/api/connect-github/callback

# ── Claude / Anthropic ────────────────────────────────────
# Get at: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-
CLAUDE_MODEL=claude-sonnet-4-6

# ── Encryption ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# ⚠️  NEVER regenerate after launch — existing tokens become unreadable
ENCRYPTION_KEY=

# ── CORS ──────────────────────────────────────────────────
# Your frontend origin(s), comma-separated. No trailing slash.
ALLOWED_ORIGINS=https://devagent-alpha.vercel.app,http://localhost:8080

# ── App ───────────────────────────────────────────────────
APP_ENV=production
APP_URL=https://your-backend.up.railway.app

# ── Proxy ─────────────────────────────────────────────────
# Railway sits behind a proxy — needed for correct IP in rate limiting
TRUST_PROXY=true
